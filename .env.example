# Vox 环境变量配置示例

# MiniMax API 配置 (必需)
MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# LLM Provider 选择 (可选，默认 minimax)
# 可选值: minimax, deepseek, moonshot, openai, azure, ollama, gemini, pollinations
LLM_PROVIDER=minimax

# DeepSeek API (可选)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Moonshot API (可选)
MOONSHOT_API_KEY=your_moonshot_api_key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# OpenAI API (可选)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Azure OpenAI (可选)
AZURE_API_KEY=your_azure_api_key
AZURE_BASE_URL=your_azure_endpoint
AZURE_API_VERSION=2024-02-15-preview

# Ollama 本地模型 (可选)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# Google Gemini (可选)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Pollinations 免费 API (可选，无需 API Key)
POLLINATIONS_BASE_URL=https://text.pollinations.ai/openai
POLLINATIONS_MODEL=openai-fast

# Tavily API (可选，用于市场调研)
TAVILY_API_KEY=your_tavily_api_key

# Pexels API (可选，用于视频素材搜索)
PEXELS_API_KEYS=your_pexels_api_key

# Pixabay API (可选，用于视频素材搜索)
PIXABAY_API_KEYS=your_pixabay_api_key

# 服务端口配置
FRONTEND_PORT=3666
BACKEND_PORT=8003

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:8003
